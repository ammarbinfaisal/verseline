# Database
DATABASE_URL=postgres://verseline:verseline@localhost:5434/verseline

# Auth
JWT_SECRET=change-me-to-a-random-secret
ALLOW_SIGNUP=true

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@verseline.ammarfaisal.me

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=verseline
R2_PUBLIC_URL=

# Geo-blocking (comma-separated ISO country codes, default: IN)
ALLOWED_COUNTRIES=IN
GEO_BLOCK_ENABLED=true

# CORS
FRONTEND_URL=http://localhost:3000

# Server
PORT=4000
