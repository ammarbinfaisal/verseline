{"start":"00:00:00.000","end":"00:00:03.000","text":"وتنشر عنك في الدنيا جميلا","confidence":0.8815677629416706}
{"start":"00:00:03.000","end":"00:00:06.000","text":"فتلقى البر فيها حيث كنت","confidence":0.8815677629416706}
{"start":"00:00:06.000","end":"00:00:09.000","text":"وتمشي في مناكبها كريما","confidence":0.8815677629416706}
{"start":"00:00:09.000","end":"00:00:12.000","text":"وتجن الحمد مما قد غرست","confidence":0.8815677629416706}
{"start":"00:00:12.000","end":"00:00:15.000","text":"وأنت الآن لم تعرف بعاب","confidence":0.8815677629416706}
{"start":"00:00:15.000","end":"00:00:18.000","text":"ولا دنست ثوبك مذنشأت","confidence":0.8815677629416706}
{"start":"00:00:18.000","end":"00:00:21.000","text":"ولا سابقت في ميدان زور","confidence":0.8815677629416706}
{"start":"00:00:21.000","end":"00:00:24.000","text":"ولا أوضعت فيه ولا خببت","confidence":0.8815677629416706}
{"start":"00:00:24.000","end":"00:00:27.000","text":"فإن لم تنأ عنه نشبت فيه","confidence":0.8815677629416706}
{"start":"00:00:27.000","end":"00:00:30.000","text":"ومن لك بالخلاص","confidence":0.7785483912342929}
