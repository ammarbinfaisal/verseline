{"start":"00:00:00.000","end":"00:00:03.580","text":"تفت فوادك الأيام فتا","confidence":0.8058800954439428}
{"start":"00:00:03.580","end":"00:00:07.080","text":"وتنحت جسمك الساعات نحتا","confidence":0.8058800954439428}
{"start":"00:00:07.080","end":"00:00:10.580","text":"وتدعوك المنون دعاء صدق","confidence":0.8058800954439428}
{"start":"00:00:10.580","end":"00:00:14.480","text":"ألا يا صاح أنت أريد أنتا","confidence":0.8058800954439428}
{"start":"00:00:14.480","end":"00:00:17.780","text":"أراك تحب عرسا ذات غدر","confidence":0.8058800954439428}
{"start":"00:00:17.780","end":"00:00:21.480","text":"أبت طلاقها الأكياس بتا","confidence":0.8058800954439428}
{"start":"00:00:21.480","end":"00:00:24.980","text":"تنام الدهر ويحك في غطيط","confidence":0.8058800954439428}
{"start":"00:00:24.980","end":"00:00:28.780","text":"بها حتى إذا مت انتبهتا","confidence":0.8058800954439428}
{"start":"00:00:28.780","end":"00:00:30.780","text":"فكم ذا أنت","confidence":0.5632736292358578}
