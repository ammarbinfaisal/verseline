{"start":"00:00:00.000","end":"00:00:03.000","text":"على ما في حياتك قد أضعتا","confidence":0.8883690132501679}
{"start":"00:00:03.000","end":"00:00:06.000","text":"تفر من الهجير وتتقيه","confidence":0.8883690132501679}
{"start":"00:00:06.000","end":"00:00:10.000","text":"فهلا عن جهنم قد فررتا","confidence":0.8883690132501679}
{"start":"00:00:10.000","end":"00:00:13.000","text":"ولست تطيق أهونها عذابا","confidence":0.8883690132501679}
{"start":"00:00:13.000","end":"00:00:16.000","text":"ولو كنت الحديد بها لذبتا","confidence":0.8883690132501679}
{"start":"00:00:16.000","end":"00:00:19.000","text":"فلا تكذب فإن الأمر جد","confidence":0.8883690132501679}
{"start":"00:00:19.000","end":"00:00:23.000","text":"وليس كما احتسبت ولا ظننتا","confidence":0.8883690132501679}
{"start":"00:00:23.000","end":"00:00:26.000","text":"أبا بكر انكشفت أقل عيبي","confidence":0.8883690132501679}
{"start":"00:00:26.000","end":"00:00:29.000","text":"وأكثره ومعظمه سترتا","confidence":0.8883690132501679}
{"start":"00:00:29.000","end":"00:00:31.000","text":"فقل لي","confidence":0.5395747249110776}
