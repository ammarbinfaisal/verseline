{"start":"00:00:00.000","end":"00:00:03.220","text":"تحمل منه في ناديك تاجاً","confidence":0.7795508874234687}
{"start":"00:00:03.220","end":"00:00:06.940","text":"ويكسوك الجمال إذا اقتربت","confidence":0.7795508874234687}
{"start":"00:00:06.940","end":"00:00:10.460","text":"ينالك نفعه ما دمت حياً","confidence":0.7795508874234687}
{"start":"00:00:10.460","end":"00:00:14.180","text":"ويبقى ذخره لك إن ذهبت","confidence":0.7795508874234687}
{"start":"00:00:14.180","end":"00:00:17.860","text":"هو العقب المهند ليس ينبو","confidence":0.7795508874234687}
{"start":"00:00:17.860","end":"00:00:22.340","text":"تصيب به مقاتل من ضربت","confidence":0.7795508874234687}
{"start":"00:00:22.340","end":"00:00:26.500","text":"وكنز لا تخاف عليه لصاً","confidence":0.7795508874234687}
{"start":"00:00:26.500","end":"00:00:29.920","text":"خفيف الحمل يوجد حيث كنت","confidence":0.675808058787199}
