{"start":"00:00:00.000","end":"00:00:02.000","text":"إذا نشبتا","confidence":0.8680437314700622}
{"start":"00:00:02.000","end":"00:00:07.000","text":"ودنس ما تطهر منك حتى","confidence":0.8680437314700622}
{"start":"00:00:07.000","end":"00:00:10.000","text":"كأنك قبل ذلك ما طهرتا","confidence":0.8680437314700622}
{"start":"00:00:10.000","end":"00:00:13.000","text":"وصرت أسير ذنبك في وثاق","confidence":0.8680437314700622}
{"start":"00:00:13.000","end":"00:00:16.000","text":"وكيف لك الفكاك وقد غسلتا","confidence":0.8680437314700622}
{"start":"00:00:16.000","end":"00:00:22.000","text":"وخف أبناء جنسك وخش منهم","confidence":0.8680437314700622}
{"start":"00:00:22.000","end":"00:00:25.000","text":"كما تخشى الضراغم والسبنتا","confidence":0.8680437314700622}
{"start":"00:00:25.000","end":"00:00:28.000","text":"وخالقهم وزائلهم حذارا","confidence":0.8680437314700622}
{"start":"00:00:28.000","end":"00:00:30.000","text":"وكن كالسامرين","confidence":0.862683676843568}
