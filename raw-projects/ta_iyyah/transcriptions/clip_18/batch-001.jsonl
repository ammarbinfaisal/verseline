{"start":"00:00:00.000","end":"00:00:04.000","text":"ولم أركق تديت بمن صحبتا","confidence":0.8589478893327047}
{"start":"00:00:04.000","end":"00:00:07.000","text":"وناداك الكتاب فلم تجبه","confidence":0.8589478893327047}
{"start":"00:00:07.000","end":"00:00:11.000","text":"ونهنهك المشيب فمن تبهتا","confidence":0.8589478893327047}
{"start":"00:00:11.000","end":"00:00:15.000","text":"ليقبح بالفتا فعل التصابي","confidence":0.8589478893327047}
{"start":"00:00:15.000","end":"00:00:18.000","text":"وأقبح منه شيخ قد تفتا","confidence":0.8589478893327047}
{"start":"00:00:18.000","end":"00:00:22.000","text":"فأنت أحق بالتثنيذ مني","confidence":0.8589478893327047}
{"start":"00:00:22.000","end":"00:00:25.000","text":"ولو سكت المسيء لما نطقتا","confidence":0.8589478893327047}
{"start":"00:00:25.000","end":"00:00:29.000","text":"ونفسك ذم لا تذم سواها","confidence":0.8589478893327047}
{"start":"00:00:29.000","end":"00:00:31.000","text":"اشتركوا في القناة","confidence":0.604852313704055}
