{"start":"00:00:00.000","end":"00:00:04.000","text":"رجعت القهقرى وخضت عشوى","confidence":0.8382194193076324}
{"start":"00:00:04.000","end":"00:00:07.000","text":"لعمرك لو وصلت لما رجعت","confidence":0.8382194193076324}
{"start":"00:00:07.000","end":"00:00:10.000","text":"ولو وافيت ربك دون ذنب","confidence":0.8382194193076324}
{"start":"00:00:10.000","end":"00:00:13.000","text":"وناقشك الحساب إذا هلكت","confidence":0.8382194193076324}
{"start":"00:00:13.000","end":"00:00:16.000","text":"ولم يظلمك في عمل ولكن","confidence":0.8382194193076324}
{"start":"00:00:16.000","end":"00:00:20.000","text":"عسير أن تقوم بما حملت","confidence":0.8382194193076324}
{"start":"00:00:20.000","end":"00:00:23.000","text":"ولو قد جئت يوم الفصل فردا","confidence":0.8382194193076324}
{"start":"00:00:23.000","end":"00:00:26.000","text":"وأبصرت المنازل فيه شتى","confidence":0.8382194193076324}
{"start":"00:00:26.000","end":"00:00:30.000","text":"لأعظمت الندامة فيه لهفا","confidence":0.7409794437026227}
