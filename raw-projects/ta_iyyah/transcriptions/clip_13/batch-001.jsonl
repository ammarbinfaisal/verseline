{"start":"00:00:00.000","end":"00:00:05.800","text":"ليوم دفن خل كأنك لا تراد بما شهدتا","confidence":0.7892557419742362}
{"start":"00:00:05.800","end":"00:00:14.300","text":"ولم تخلق لتعمرها ولكن لتعبرها فجد لما خلقتا","confidence":0.7892557419742362}
{"start":"00:00:14.300","end":"00:00:17.700","text":"وإن هدمت فزدها أنت هدما","confidence":0.7892557419742362}
{"start":"00:00:17.700","end":"00:00:21.400","text":"وحص أمر دينك ما استطعتا","confidence":0.7892557419742362}
{"start":"00:00:21.400","end":"00:00:25.000","text":"ولا تحزن على ما فات منها","confidence":0.7892557419742362}
{"start":"00:00:25.000","end":"00:00:28.600","text":"إذا ما أنت في بخراك فزتا","confidence":0.7892557419742362}
{"start":"00:00:28.600","end":"00:00:30.600","text":"فليس بنافع","confidence":0.6676149629031981}
