{"start":"00:00:00.000","end":"00:00:02.400","text":"بريقك قد شرقتا","confidence":0.8453264139111714}
{"start":"00:00:02.400","end":"00:00:05.360","text":"فليس الزهد في الدنيا خمولا","confidence":0.8453264139111714}
{"start":"00:00:05.360","end":"00:00:08.640","text":"لأنت بها الأمير إذا زهدتا","confidence":0.8453264139111714}
{"start":"00:00:08.640","end":"00:00:11.680","text":"ولو فوق الأمير تكون فيها","confidence":0.8453264139111714}
{"start":"00:00:11.680","end":"00:00:15.360","text":"سموا وافتخارا كنت أنتا","confidence":0.8453264139111714}
{"start":"00:00:15.360","end":"00:00:18.480","text":"وإن فرقتها وخرجت منها","confidence":0.8453264139111714}
{"start":"00:00:18.480","end":"00:00:21.600","text":"إلى دار السلام فقد سلمتا","confidence":0.8453264139111714}
{"start":"00:00:21.600","end":"00:00:24.720","text":"وإن كرمتها ونظرت فيها","confidence":0.8453264139111714}
{"start":"00:00:24.720","end":"00:00:28.080","text":"بإجلال فنفسك قد أهنتا","confidence":0.8453264139111714}
{"start":"00:00:28.080","end":"00:00:30.160","text":"جمعت لك النصارى","confidence":0.7554497817982594}
