{"start":"00:00:00.000","end":"00:00:04.000","text":"وإن جلس الغني على الحشايا","confidence":0.8438221757243539}
{"start":"00:00:04.000","end":"00:00:07.000","text":"لأنت على الكواكب قد جلست","confidence":0.8438221757243539}
{"start":"00:00:07.000","end":"00:00:11.000","text":"وإن ركب الجياد مسومات","confidence":0.8438221757243539}
{"start":"00:00:11.000","end":"00:00:15.000","text":"لأنت مناهج التقوى ركبت","confidence":0.8438221757243539}
{"start":"00:00:15.000","end":"00:00:18.000","text":"ومهما افتض أبكار الغواني","confidence":0.8438221757243539}
{"start":"00:00:18.000","end":"00:00:21.000","text":"فكم بكر من الحكم افتضت","confidence":0.8438221757243539}
{"start":"00:00:21.000","end":"00:00:25.000","text":"وليس يضرك الإقتار شيئا","confidence":0.8438221757243539}
{"start":"00:00:25.000","end":"00:00:28.000","text":"إذا ما أنت ربك قد عرفت","confidence":0.8438221757243539}
{"start":"00:00:28.000","end":"00:00:31.000","text":"فماذا ستفعل","confidence":0.43013194211120975}
