{"start":"00:00:00.000","end":"00:00:03.880","text":"بعيب فهي أجدر من ذممت","confidence":0.7985026470818835}
{"start":"00:00:03.880","end":"00:00:07.680","text":"فلو بكت الدماء عيناك خوفا","confidence":0.7985026470818835}
{"start":"00:00:07.680","end":"00:00:11.080","text":"لذنبك لم أقل لك قد أمنت","confidence":0.7985026470818835}
{"start":"00:00:11.080","end":"00:00:14.520","text":"ومن لك بالأمان وأنت عبد","confidence":0.7985026470818835}
{"start":"00:00:14.520","end":"00:00:17.960","text":"أمرت فمأتمرت ولا أطعت","confidence":0.7985026470818835}
{"start":"00:00:17.960","end":"00:00:21.400","text":"فقلت من الذنوب ولست تخشى","confidence":0.7985026470818835}
{"start":"00:00:21.400","end":"00:00:24.800","text":"لجهلك أن تخف إذا أزنت","confidence":0.7985026470818835}
{"start":"00:00:24.800","end":"00:00:28.040","text":"وتشفق للمصر على المعاصي","confidence":0.7985026470818835}
{"start":"00:00:28.040","end":"00:00:30.160","text":"وترحمه ونفسك","confidence":0.6636837182688471}
