{"start":"00:00:00.000","end":"00:00:03.000","text":"أنا لم أخب بحر الخطايا","confidence":0.8582841427453413}
{"start":"00:00:03.000","end":"00:00:07.000","text":"كما قد خبته حتى غرقتا","confidence":0.8582841427453413}
{"start":"00:00:07.000","end":"00:00:10.000","text":"ولم أشرب حميا أم دفر","confidence":0.8582841427453413}
{"start":"00:00:10.000","end":"00:00:14.000","text":"وأنت شربتها حتى سكرتا","confidence":0.8582841427453413}
{"start":"00:00:14.000","end":"00:00:17.000","text":"ولم أحل البواد فيه ظلم","confidence":0.8582841427453413}
{"start":"00:00:17.000","end":"00:00:21.000","text":"وأنت حللت فيه وانهملتا","confidence":0.8582841427453413}
{"start":"00:00:21.000","end":"00:00:24.000","text":"ولم أنشأ بعصر فيه نفع","confidence":0.8582841427453413}
{"start":"00:00:24.000","end":"00:00:27.000","text":"وأنت نشأت فيه ومن تفعتا","confidence":0.8582841427453413}
{"start":"00:00:27.000","end":"00:00:30.000","text":"وقد صاحبت علام كبير","confidence":0.8058997056433872}
