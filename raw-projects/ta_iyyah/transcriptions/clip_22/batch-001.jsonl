{"start":"00:00:00.000","end":"00:00:02.700","text":"ما شئت في من المخازي","confidence":0.8173675198765074}
{"start":"00:00:02.700","end":"00:00:06.000","text":"وضاعفها فإنك قد صدقتا","confidence":0.8173675198765074}
{"start":"00:00:06.000","end":"00:00:12.500","text":"ومهما عبتني فلفرط علمي بباطنتي كأنك قد مدحتا","confidence":0.8173675198765074}
{"start":"00:00:12.500","end":"00:00:18.500","text":"فلا ترضى المعايب فهي عار عظيم يورث الإنسان مقتا","confidence":0.8173675198765074}
{"start":"00:00:18.500","end":"00:00:22.000","text":"وتهوي بالوجيه من الثريا","confidence":0.8173675198765074}
{"start":"00:00:22.000","end":"00:00:25.000","text":"وتبدله مكان الفوق تحتا","confidence":0.8173675198765074}
{"start":"00:00:25.000","end":"00:00:28.000","text":"كما الطاعة تنعلك الدراري","confidence":0.8173675198765074}
{"start":"00:00:28.000","end":"00:00:30.000","text":"وتجعلك القريبة","confidence":0.7356596473712178}
